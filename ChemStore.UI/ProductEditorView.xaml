<Window
    x:Class="ChemStore.UI.Views.ProductEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="الصنف"
    Width="900"
    Height="650"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl>

            <TabItem Header="البيانات الأساسية">

                <Grid Margin="15">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="45"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="الكود"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding Product.Code}"/>

                    <TextBlock Grid.Row="1"
                               Text="الباركود"/>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding Product.Barcode}"/>

                    <TextBlock Grid.Row="2"
                               Text="اسم الصنف"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding Product.Name}"/>

                    <TextBlock Grid.Row="3"
                               Text="التصنيف"/>

                    <ComboBox Grid.Row="3"
                              Grid.Column="1"/>

                    <TextBlock Grid.Row="4"
                               Text="الشركة"/>

                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Text="{Binding Product.Manufacturer}"/>

                    <TextBlock Grid.Row="5"
                               Text="المادة الفعالة"/>

                    <TextBox Grid.Row="5"
                             Grid.Column="1"
                             Text="{Binding Product.ActiveIngredient}"/>

                    <TextBlock Grid.Row="6"
                               Text="الحد الأدنى"/>

                    <TextBox Grid.Row="6"
                             Grid.Column="1"
                             Text="{Binding Product.MinimumStock}"/>

                </Grid>

            </TabItem>

            <TabItem Header="الوحدات"/>

            <TabItem Header="الأسعار"/>

            <TabItem Header="المخزون"/>

            <TabItem Header="صورة الصنف"/>

        </TabControl>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Width="120"
                    Margin="5"
                    Content="حفظ"/>

            <Button Width="120"
                    Margin="5"
                    Content="إلغاء"/>

        </StackPanel>

    </Grid>

</Window>
